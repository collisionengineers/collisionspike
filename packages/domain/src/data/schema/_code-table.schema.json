{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "_code-table.schema.json",
  "title": "CollisionSpike code-table metadata",
  "oneOf": [
    {
      "allOf": [
        { "$ref": "#/$defs/codeTable" },
        {
          "type": "object",
          "required": ["$schema", "kind"],
          "properties": {
            "$schema": { "type": "string" },
            "kind": { "const": "code-table" }
          }
        }
      ]
    },
    {
      "type": "object",
      "required": ["$schema", "kind", "codeTables"],
      "properties": {
        "$schema": { "type": "string" },
        "kind": { "const": "code-table-bundle" },
        "description": { "type": "string" },
        "codeTables": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/codeTable" }
        }
      }
    }
  ],
  "$defs": {
    "codeTable": {
      "type": "object",
      "required": ["codeTableId", "displayName", "options"],
      "properties": {
        "codeTableId": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "default": { "type": "string" },
        "parityKey": { "type": "string" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/option" }
        },
        "stateMachine": { "type": "object" }
      }
    },
    "option": {
      "type": "object",
      "required": ["value", "name", "label"],
      "properties": {
        "value": { "type": "integer" },
        "name": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "classifierEmits": { "type": "boolean" }
      }
    }
  }
}
