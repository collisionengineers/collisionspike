{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://collisionengineers.example/contracts/eva-payload.schema.json",
  "title": "EVA payload (12-field, settled contract)",
  "description": "VENDORED COPY (ships inside the parser deployment package). Source of truth is the repo-root contracts/eva-payload.schema.json; this copy exists because .funcignore can only ship files INSIDE functions/parser/, and the FC1 deployment package therefore cannot reach the repo-root contracts/ dir. schema_validation._default_schema_path() resolves this package-local copy when deployed, the repo-root copy in local dev/tests. Kept identical by tests/test_schema_vendored_in_sync.py. Cross-language keystone for the Collision Engineers EVA drag-drop JSON payload. Exactly the 12 settled snake_case fields in contract order; vrm and reference are Case-identity fields and are intentionally NOT part of this payload.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "work_provider",
    "vehicle_model",
    "claimant_name",
    "claimant_telephone",
    "claimant_email",
    "date_of_loss",
    "date_of_instruction",
    "accident_circumstances",
    "inspection_address",
    "vat_status",
    "mileage",
    "mileage_unit"
  ],
  "propertyNames": {
    "enum": [
      "work_provider",
      "vehicle_model",
      "claimant_name",
      "claimant_telephone",
      "claimant_email",
      "date_of_loss",
      "date_of_instruction",
      "accident_circumstances",
      "inspection_address",
      "vat_status",
      "mileage",
      "mileage_unit"
    ]
  },
  "properties": {
    "work_provider": {
      "type": "string",
      "minLength": 1,
      "description": "Field 1. Required non-empty."
    },
    "vehicle_model": {
      "type": "string",
      "minLength": 1,
      "description": "Field 2. Required non-empty."
    },
    "claimant_name": {
      "type": "string",
      "description": "Field 3."
    },
    "claimant_telephone": {
      "type": "string",
      "description": "Field 4."
    },
    "claimant_email": {
      "type": "string",
      "description": "Field 5."
    },
    "date_of_loss": {
      "type": "string",
      "pattern": "^(\\d{2}/\\d{2}/\\d{4})?$",
      "description": "Field 6. DD/MM/YYYY or empty."
    },
    "date_of_instruction": {
      "type": "string",
      "pattern": "^(\\d{2}/\\d{2}/\\d{4})?$",
      "description": "Field 7. DD/MM/YYYY or empty."
    },
    "accident_circumstances": {
      "type": "string",
      "description": "Field 8."
    },
    "inspection_address": {
      "type": "string",
      "description": "Field 9. Exactly six newline-separated lines, OR the literal 'Image Based Assessment'.",
      "oneOf": [
        {
          "const": "Image Based Assessment"
        },
        {
          "pattern": "^[^\\n]*(\\n[^\\n]*){5}$"
        }
      ]
    },
    "vat_status": {
      "type": "string",
      "enum": ["", "Yes", "No"],
      "description": "Field 10. Blank, Yes, or No."
    },
    "mileage": {
      "type": "string",
      "pattern": "^\\d*$",
      "description": "Field 11. Digits only or empty."
    },
    "mileage_unit": {
      "type": "string",
      "enum": ["", "Miles", "Km"],
      "description": "Field 12. Blank, Miles, or Km."
    }
  }
}
