{
  "$schema": "./_table.schema.json",
  "logicalName": "cr1bd_note",
  "displayName": "Note",
  "displayCollectionName": "Notes",
  "schemaName": "cr1bd_Note",
  "description": "Free-text note on a case. First-class and always available (a custom table, deliberately NOT the platform annotation entity, so it stays in the solution's typed model and the prototype Note shape).",
  "ownership": "UserOwned",
  "lifecycle": { "state": "staged", "note": "Defined and staged; always available in the Code App. Minimal in M1." },
  "primaryColumn": {
    "logicalName": "cr1bd_name",
    "displayName": "Title",
    "type": "String",
    "maxLength": 200,
    "required": "none",
    "description": "Optional short title; the body lives in cr1bd_text."
  },
  "columns": [
    { "logicalName": "cr1bd_caseid", "displayName": "Case", "type": "Lookup", "target": "cr1bd_case", "relationshipSchemaName": "cr1bd_case_note", "required": "required", "description": "-> Case (parent). 1:N Case->Note; cascade." },
    { "logicalName": "cr1bd_author", "displayName": "Author", "type": "String", "maxLength": 200, "required": "recommended", "description": "Note author (staff display name)." },
    { "logicalName": "cr1bd_text", "displayName": "Text", "type": "Memo", "maxLength": 8000, "required": "required", "description": "Free-text note body." },
    { "logicalName": "cr1bd_occurredat", "displayName": "Timestamp", "type": "DateTime", "dateTimeBehavior": "UserLocal", "required": "none", "description": "Domain timestamp of the note (distinct from platform createdon)." }
  ]
}
