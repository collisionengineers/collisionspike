{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://collisionspike/dataverse/_choiceset.schema.json",
  "title": "CollisionSpike Dataverse choice set (authoring spec)",
  "description": "Authoring shape for a global option set (choice set). Local build/ajv validation only — NOT a Dataverse import format. The dataverse-data-architect maps `options[].value`/`name`/`label` to OptionMetadata (Value / external name / Label) at import time via pac/Web API.",
  "type": "object",
  "oneOf": [
    {
      "required": ["kind", "logicalName", "displayName", "options"],
      "properties": { "kind": { "const": "global-choice-set" } }
    },
    {
      "required": ["kind", "choiceSets"],
      "properties": { "kind": { "const": "global-choice-set-bundle" } }
    }
  ],
  "properties": {
    "$schema": { "type": "string" },
    "kind": { "enum": ["global-choice-set", "global-choice-set-bundle"] },
    "logicalName": { "type": "string", "pattern": "^cr1bd_[a-z0-9]+$" },
    "displayName": { "type": "string" },
    "description": { "type": "string" },
    "isGlobal": { "type": "boolean" },
    "default": { "type": "string" },
    "parityKey": { "type": "string" },
    "stateMachine": { "type": "object" },
    "choiceSets": { "type": "array", "items": { "type": "object" } },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["value", "name", "label"],
        "additionalProperties": false,
        "properties": {
          "value": { "type": "integer" },
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
