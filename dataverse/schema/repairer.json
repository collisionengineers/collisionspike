{
  "$schema": "./_table.schema.json",
  "logicalName": "cr1bd_repairer",
  "displayName": "Repairer",
  "displayCollectionName": "Repairers",
  "schemaName": "cr1bd_Repairer",
  "description": "First-class entity (ADR-0001): a garage/bodyshop CE interacts with (from the job sheet's Garages tab, ~38 rows). A reusable directory chased for images/figures. MANY-TO-MANY with WorkProvider (one repairer serves several providers; one provider uses several repairers).",
  "ownership": "UserOwned",
  "lifecycle": { "state": "staged", "note": "Defined and staged; 1b import writes; Case/InspectionAddress read. Not deployed in the M1 four." },
  "primaryColumn": {
    "logicalName": "cr1bd_name",
    "displayName": "Name",
    "type": "String",
    "maxLength": 200,
    "required": "required",
    "description": "Garage / bodyshop name."
  },
  "columns": [
    { "logicalName": "cr1bd_addressline1", "displayName": "Address Line 1", "type": "String", "maxLength": 200, "required": "none", "description": "6-line address, line 1." },
    { "logicalName": "cr1bd_addressline2", "displayName": "Address Line 2", "type": "String", "maxLength": 200, "required": "none", "description": "6-line address, line 2." },
    { "logicalName": "cr1bd_addressline3", "displayName": "Address Line 3", "type": "String", "maxLength": 200, "required": "none", "description": "6-line address, line 3." },
    { "logicalName": "cr1bd_addressline4", "displayName": "Address Line 4", "type": "String", "maxLength": 200, "required": "none", "description": "6-line address, line 4." },
    { "logicalName": "cr1bd_addressline5", "displayName": "Address Line 5", "type": "String", "maxLength": 200, "required": "none", "description": "6-line address, line 5." },
    { "logicalName": "cr1bd_addressline6", "displayName": "Address Line 6", "type": "String", "maxLength": 200, "required": "none", "description": "6-line address, line 6." },
    { "logicalName": "cr1bd_postcode", "displayName": "Postcode", "type": "String", "maxLength": 16, "required": "none", "description": "UK postcode (normalised via postcode.io)." },
    { "logicalName": "cr1bd_email", "displayName": "Email", "type": "String", "maxLength": 320, "format": "Email", "required": "none", "description": "Contact email." },
    { "logicalName": "cr1bd_phone", "displayName": "Phone", "type": "String", "maxLength": 60, "required": "none", "description": "Contact phone." },
    { "logicalName": "cr1bd_figuresexpected", "displayName": "Figures Expected", "type": "Boolean", "required": "none", "description": "Job sheet Garages 'Figures' column -- whether the repairer supplies their own estimate figures." },
    { "logicalName": "cr1bd_active", "displayName": "Active", "type": "Boolean", "required": "none", "description": "active|archived. Referenced repairers are never deleted -- deactivate/archive/merge." }
  ],
  "alternateKeys": [
    { "schemaName": "cr1bd_repairer_name_postcode_key", "displayName": "Name + Postcode Key", "columns": ["cr1bd_name", "cr1bd_postcode"], "description": "Natural key for job-sheet upsert / dedup of Garages rows." }
  ],
  "notes": [
    "N:N to WorkProvider (ADR-0001) defined in relationships.json (cr1bd_repairer_workprovider).",
    "InspectionAddress.repairerId references this table for the most-common physical-location case."
  ]
}
