# Excluded from the deployment package (config-zip / func azure publish).
# The FC1 remote Oryx build installs requirements.txt on the Linux worker, so
# local venvs, caches, tests, and infra/openapi tooling must NOT ship.
.venv/
.venv_headless/
__pycache__/
*.pyc
.pytest_cache/
tests/
scripts/
local.settings.json
local.settings.json.TEMPLATE
requirements-dev.txt
infra/
README.md
.gitignore
