# Normalize source text to LF in Git and in clean checkouts.
* text=auto
*.cjs  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.jsx  text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.sql  text eol=lf
*.toml text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
scripts/hooks/* text eol=lf

# Keep the immutable working files byte-stable in Windows checkouts while preserving rename-equivalent Git blobs.
workingspace/** text eol=crlf -diff
# Binary source evidence must never be line-ending converted.
tests/fixtures/evidence/** -text -diff
*.png   binary
*.jpg   binary
*.jpeg  binary
*.avif  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   binary
*.otf   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.pdf   binary
*.eml   binary
*.msg   binary
*.boxnote binary
*.doc   binary
*.docx  binary
*.ppt   binary
*.pptx  binary
*.xls   binary
*.xlsx  binary
*.mov   binary
*.mp4   binary
*.zip   binary
