# Normalise text to LF in the repo; let git pick native EOL on checkout.
* text=auto

# This source historically contained a raw NUL delimiter and CRLF bytes, which made
# `text=auto` classify the old blob as binary. Preserve its existing byte-level line
# endings for this transition, but force a text diff so the escaped delimiter and
# future changes remain reviewable line by line.
orchestration/src/functions/gated/retro-case.ts -text diff whitespace=cr-at-eol

# Binary assets must NEVER be line-ending-converted (CRLF mangling corrupts them —
# this is the failure class behind the broken deployed logo). Treat as binary.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   binary
*.otf   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.pdf   binary
*.eml   binary
*.doc   binary
*.docx  binary
*.pptx  binary
*.xls   binary
*.xlsx  binary
*.zip   binary
