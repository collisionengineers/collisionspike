{
  "schemaVersion": 1,
  "rootName": "collisionspike",
  "rootScripts": {
    "build": "npm run build --workspace @cs/domain && npm run build --workspace @cs/api && npm run build --workspace @cs/orchestration",
    "build:api": "npm run build --workspace @cs/api",
    "build:domain": "npm run build --workspace @cs/domain",
    "build:orch": "npm run build --workspace @cs/orchestration",
    "check:data-authority": "node scripts/check-repository-data-authority.mjs",
    "test": "npm run test --workspace @cs/domain && npm run test --workspace mockup-app && npm run test:tkt150-remediation",
    "test:data-authority": "node --test scripts/check-repository-data-authority.test.mjs",
    "test:tkt150-remediation": "node --test scripts/live/remediate-blank-claimants.test.mjs"
  },
  "workspacePatterns": [
    "api",
    "mockup-app",
    "orchestration",
    "packages/*"
  ],
  "packages": [
    {
      "packagePath": "api",
      "name": "@cs/api",
      "version": "0.0.0",
      "private": true,
      "type": "module",
      "main": "dist/src/index.js",
      "exports": null,
      "scripts": {
        "build": "tsc -b",
        "dev": "func start",
        "start": "func start",
        "test": "vitest run"
      },
      "dependencies": {
        "@azure/functions": "^4.5.0",
        "@azure/storage-blob": "^12.25.0",
        "@cs/domain": "*",
        "jose": "^5.9.6",
        "pg": "^8.13.1",
        "sharp": "^0.35.3"
      },
      "devDependencies": {
        "@types/pg": "^8.11.10",
        "typescript": "^5.6.3",
        "vitest": "^4.1.9"
      },
      "peerDependencies": {}
    },
    {
      "packagePath": "mockup-app",
      "name": "collisionspike-mockup",
      "version": "0.1.0",
      "private": true,
      "type": "module",
      "main": null,
      "exports": null,
      "scripts": {
        "build": "tsc -b && vite build",
        "dev": "vite",
        "preview": "vite preview",
        "test": "vitest run"
      },
      "dependencies": {
        "@azure/msal-browser": "^3.28.0",
        "@azure/msal-react": "^2.1.0",
        "@cs/domain": "*",
        "@dnd-kit/core": "^6.1.0",
        "@dnd-kit/sortable": "^8.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fluentui/react-components": "^9.54.0",
        "@fluentui/react-datepicker-compat": "^0.6.34",
        "fflate": "^0.8.3",
        "lucide-react": "^0.456.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.26.2"
      },
      "devDependencies": {
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.3",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "jsdom": "^26.1.0",
        "typescript": "^5.6.3",
        "vite": "^5.4.10",
        "vitest": "^4.1.9"
      },
      "peerDependencies": {}
    },
    {
      "packagePath": "orchestration",
      "name": "@cs/orchestration",
      "version": "0.0.0",
      "private": true,
      "type": "module",
      "main": "dist/src/index.js",
      "exports": null,
      "scripts": {
        "build": "tsc -b",
        "dev": "func start",
        "start": "func start",
        "test": "vitest run"
      },
      "dependencies": {
        "@azure/functions": "^4.5.0",
        "@azure/storage-blob": "^12.25.0",
        "@cs/domain": "*",
        "durable-functions": "^3.3.2"
      },
      "devDependencies": {
        "typescript": "^5.6.3",
        "vitest": "^4.1.9"
      },
      "peerDependencies": {}
    },
    {
      "packagePath": "packages/domain",
      "name": "@cs/domain",
      "version": "0.0.0",
      "private": true,
      "type": "module",
      "main": null,
      "exports": {
        ".": {
          "import": "./dist/index.js",
          "types": "./src/index.ts"
        },
        "./codecs": {
          "import": "./dist/codecs/index.js",
          "types": "./src/codecs/index.ts"
        },
        "./gates": {
          "import": "./dist/gates.js",
          "types": "./src/gates.ts"
        }
      },
      "scripts": {
        "build": "tsc -b",
        "test": "vitest run"
      },
      "dependencies": {
        "zod": "^3.23.8",
        "zod-to-json-schema": "^3.23.5"
      },
      "devDependencies": {
        "ajv": "^8.17.1",
        "typescript": "^5.6.3",
        "vitest": "^4.1.9"
      },
      "peerDependencies": {}
    }
  ],
  "packageLock": {
