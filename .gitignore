venv/
.pytest_cache/

# Project evidence, evaluation inputs, responses, logs, hashes, versions and costs may be
# tracked when they are authorised project material. Recovery bundles and database dumps belong
# under the external `collisionsuite-recovery` hierarchy, never in a checkout.
*.pyc
*.egg-info/
boxconfig.json
# Box JWT app config (downloaded Box "Config.JSON" — contains the RSA private key,
# passphrase, client secret + webhook keys). NEVER commit; it lives in Key Vault.
# Box names downloads as <enterpriseId>_<keyId>_config.json (single underscores), so the
# old double-underscore patterns missed them — match both forms.
941197__config.json
*__config.json
*_config.json
[0-9]*_config.json

# WSL/Windows download marker streams (e.g. <file>:Zone.Identifier) — never useful in-repo.
*:Zone.Identifier
*:OECustomProperty

# Defense-in-depth: NTFS interprets ':' in a filename as an Alternate-Data-Stream separator;
# core.protectNTFS then refuses such a path in ANY index or working tree on Windows — not just
# checkout, but even via plumbing (git read-tree, update-index --cacheinfo). No config toggle
# around this. A colon-bearing path reaching a shared branch permanently blocks every Windows
# clone. Block all colon-bearing filenames, not just known suffixes.
*:*
