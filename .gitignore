# raw/ — drop-zone for source material to distill (contains real PII:
# claimant data in the job sheet, garage/solicitor contacts). Examined and
# distilled into docs/, but NOT committed. Keep PII out of git history.
raw/

# Dataverse corpus snapshots (16a-backup-inspectionaddress.ps1) — live cr1bd_inspectionaddress
# row dumps contain real PII (claimant/site addresses). Local restore points only; NOT committed.
dataverse/.build/backups/
*.pyc
*.egg-info/
boxconfig.json
# Box JWT app config (downloaded Box "Config.JSON" — contains the RSA private key,
# passphrase, client secret + webhook keys). NEVER commit; it lives in Key Vault.
# Box names downloads as <enterpriseId>_<keyId>_config.json (single underscores), so the
# old double-underscore patterns missed them — match both forms.
941197__config.json
*__config.json
*_config.json
[0-9]*_config.json

# WSL/Windows download marker streams (e.g. <file>:Zone.Identifier) — never useful in-repo.
*:Zone.Identifier
*:OECustomProperty
