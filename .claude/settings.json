{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__.*(create_pull_request|create_pr|merge_pull_request|merge_pr|ready_for_review|mark.*ready|enable_auto_merge|auto.*merge).*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/pr-review.mjs"],
            "timeout": 1800,
            "statusMessage": "Preparing mandatory Claude and Codex PR reviews"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/box-scope-guard.mjs"]
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/azure-route-guard.mjs"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/box-scope-postcreate.mjs"]
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/azure-churn-guard.mjs"]
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "azure@claude-plugins-official": true
  }
}
