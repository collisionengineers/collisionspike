{
  "name": "collisionspike",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/data-api",
    "services/orchestration"
  ],
  "scripts": {
    "build": "npm run build --workspace @cs/domain && npm run build --workspace @cs/api && npm run build --workspace @cs/orchestration && npm run build --workspace @cs/web",
    "build:domain": "npm run build --workspace @cs/domain",
    "build:api": "npm run build --workspace @cs/api",
    "build:orch": "npm run build --workspace @cs/orchestration",
    "build:web": "npm run build --workspace @cs/web",
    "contract:capture:lint": "redocly lint contracts/capture.v1.yaml",
    "contract:capture:generate": "openapi-typescript contracts/capture.v1.yaml -o services/data-api/src/generated/capture-api.ts",
    "contract:capture:check": "npm run contract:capture:lint && node scripts/checks/check-capture-contract.mjs",
    "bundle": "npm run bundle:api && npm run bundle:orchestration",
    "bundle:api": "node scripts/build/build-api.cjs",
    "bundle:orchestration": "node scripts/build/build-orchestration.cjs",
    "test": "npm run test --workspace @cs/domain && npm run test --workspace @cs/api && npm run test --workspace @cs/orchestration && npm run test --workspace @cs/web",
    "generate:runtime-contract": "node scripts/checks/check-runtime-contract.mjs --write",
    "verify:offline": "node scripts/verify-offline.mjs",
    "test:worktree-governance": "node --test scripts/worktree.test.mjs scripts/pre-push.test.mjs",
    "hygiene": "node scripts/repository-hygiene.mjs",
    "verify": "node verify-all.mjs",
    "check:docs": "node scripts/checks/check-doc-links.mjs",
    "check:tickets": "node scripts/checks/check-tickets.mjs",
    "check:data-authority": "node scripts/checks/check-repository-data-authority.mjs",
    "test:data-authority": "node --test scripts/checks/check-repository-data-authority.test.mjs",
    "test:checks": "node --test scripts/checks/*.test.mjs scripts/maintenance/*.test.mjs",
    "check:database": "node database/tests/code-table-parity.mjs",
    "check:evidence": "node scripts/maintenance/evidence-catalog.mjs check",
    "check:adapters": "node scripts/maintenance/generate-agent-adapters.mjs --check",
    "check:outputs": "node scripts/checks/check-tracked-outputs.mjs",
    "check:line-endings": "node scripts/maintenance/normalize-line-endings.mjs --check",
    "check:forbidden": "node scripts/checks/check-forbidden-references.mjs",
    "check:binary-content": "python scripts/checks/check-binary-content.py",
    "check:image-review": "node scripts/checks/check-image-review.mjs",
    "check:production-dependencies": "node scripts/checks/check-production-dependencies.mjs",
    "check:source-size": "node scripts/checks/check-source-size.mjs",
    "check:inventory": "node scripts/maintenance/generate-repository-inventory.mjs --check",
    "check:reconciliation": "node scripts/maintenance/reconcile-repository-reset.mjs",
    "inventory:checkout": "node scripts/maintenance/generate-checkout-inventory.mjs",
    "check:layout": "node scripts/checks/check-repository-layout.mjs",
    "check:runtime-contract": "node scripts/checks/check-runtime-contract.mjs"
  },
  "dependencies": {
    "@azure/storage-blob": "12.33.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.38.0",
    "esbuild": "0.28.1",
    "openapi-typescript": "^7.13.0"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "0.35.3",
    "@rolldown/binding-linux-x64-gnu": "1.1.3",
    "@rollup/rollup-linux-x64-gnu": "4.62.2"
  },
  "engines": {
    "node": ">=20.19"
  }
}
