#!/bin/sh
# pre-commit — repository contract guard for collisionspike.
#
# Activation (one-time, per clone — .git/hooks is NOT tracked):
#     git config core.hooksPath scripts/hooks
# See docs/governance/repository-map.md.
#
# What it does:
#   1. BLOCKS the commit if a staged path contains a ':' (invalid on Windows).
#   2. BLOCKS broken documentation links or an inconsistent ticket system.
#   3. BLOCKS generated agent-adapter drift and tracked generated output.
#   4. BLOCKS forbidden terminology, paths, and repository artifacts.
#   5. WARNS (does NOT block) if docs/operations/live-environment.md is staged
#      but LIVE_FACTS.json is not — a possible un-mirrored live edit. The registry
#      mirror and LIVE_FACTS.json should move together.
#
# Bypass (use sparingly, e.g. a WIP commit mid-restructure):  git commit --no-verify

# Resolve repo root so the hook works regardless of the invoking cwd.
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

STAGED="$(git diff --cached --name-only)"

# --- 1. Windows/NTFS-invalid path gate (BLOCKING) ---
BAD_PATHS="$(printf '%s\n' "$STAGED" | grep ':' || true)"
if [ -n "$BAD_PATHS" ]; then
  echo ""
  echo "pre-commit: BLOCKED — staged path(s) contain a ':' (NTFS-invalid on Windows):"
  printf '%s\n' "$BAD_PATHS" | sed 's/^/  /'
  echo "  Rename the file (no colon) before committing, or bypass once with: git commit --no-verify"
  exit 1
fi

# --- 2. Documentation and ticket gates (BLOCKING) ---
if command -v node >/dev/null 2>&1; then
  if ! node scripts/checks/check-doc-links.mjs --quiet; then
    echo ""
    echo "pre-commit: doc-links check FAILED — commit blocked."
    echo "  Fix the issues above, or bypass once with:  git commit --no-verify"
    exit 1
  fi
  if ! node scripts/checks/check-tickets.mjs --quiet; then
    echo ""
    echo "pre-commit: ticket-system check FAILED — commit blocked."
    echo "  Fix the issues above, or bypass once with:  git commit --no-verify"
    exit 1
  fi
else
  echo "pre-commit: node not found — skipping documentation and ticket checks (install Node to enable)."
fi

# --- 3. Generated-adapter and output gates (BLOCKING) ---
if command -v node >/dev/null 2>&1; then
  if ! node scripts/maintenance/generate-agent-adapters.mjs --check; then
    echo ""
    echo "pre-commit: generated adapter check FAILED — commit blocked."
    exit 1
  fi
  node scripts/checks/check-tracked-outputs.mjs || exit 1
fi

# --- 4. Repository terminology and artifact gate (BLOCKING) ---
if command -v node >/dev/null 2>&1; then
  node scripts/checks/check-forbidden-references.mjs || exit 1
fi

# --- 5. Registry-mirror co-staging WARNING (non-blocking) ---
echo "$STAGED" | grep -qx "docs/operations/live-environment.md"
MIRROR_STAGED=$?
echo "$STAGED" | grep -qx "LIVE_FACTS.json"
FACTS_STAGED=$?
if [ "$MIRROR_STAGED" -eq 0 ] && [ "$FACTS_STAGED" -ne 0 ]; then
  echo ""
  echo "pre-commit WARNING: docs/operations/live-environment.md is staged but LIVE_FACTS.json is NOT."
  echo "  The registry mirror and LIVE_FACTS.json should change together. If you edited a live"
  echo "  number, update LIVE_FACTS.json (bump lastVerified) too. (Warning only — commit allowed.)"
fi

exit 0
